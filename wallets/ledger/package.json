    "@ledgerhq/hw-transport-webhid": "^6.29.4",
    "@solana/web3.js": "^1.87.6",
    "@zondax/ledger-cosmos-js": "^4.0.0",
    "bs58": "^6.0.0",
    "buffer": "^6.0.3",
