{
  "name": "@interchain-kit/mock-wallet",
  "version": "0.7.0",
  "author": "Cosmology <developers@hyperweb.io>",
  "description": "interchain-kit wallet connector",
  "main": "index.js",
  "module": "esm/index.js",
  "types": "index.d.ts",
  "homepage": "https://github.com/@interchain-kit/mock-wallet",
  "license": "SEE LICENSE IN LICENSE",
  "publishConfig": {
    "access": "public",
    "directory": "dist"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/@interchain-kit/mock-wallet"
  },
  "bugs": {
    "url": "https://github.com/@interchain-kit/mock-wallet/issues"
  },
  "scripts": {
    "clean": "makage clean",
    "build": "rm -rf dist && (tsc -p tsconfig.json || true) && (tsc -p tsconfig.esm.json || true) && cp ../../LICENSE dist/ && cp package.json dist/ && cp README.md dist/",
    "build:dev": "npm run clean; tsc --declarationMap; tsc -p tsconfig.esm.json; npm run copy",
    "lint": "eslint . --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "watch:dev": "tsc -w -p tsconfig.esm.json & tsc -w",
    "prepack": "npm run build"
  },
  "keywords": [],
  "dependencies": {
    "@interchain-kit/core": "workspace:*",
    "@solana/web3.js": "^1.98.4",
    "bip39": "^3.1.0",
    "bs58": "^6.0.0",
    "ed25519-hd-key": "^1.3.0",
    "ethers": "^6.15.0",
    "tweetnacl": "^1.0.3",
    "@chain-registry/types": "^2.0.1",
    "@cosmjs/amino": "^0.32.3",
    "@cosmjs/proto-signing": "^0.32.3",
    "@keplr-wallet/types": "^0.12.168"
  },
  "devDependencies": {
    "makage": "^0.1.12"
  }
}
