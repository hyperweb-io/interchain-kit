{
  "name": "@interchain-kit/shell-extension",
  "version": "0.7.0",
  "author": "Constructive <developers@constructive.io>",
  "description": "interchain-kit wallet connector",
  "main": "index.js",
  "module": "esm/index.js",
  "types": "index.d.ts",
  "homepage": "https://github.com/interchain-kit/shell-extension",
  "license": "SEE LICENSE IN LICENSE",
  "publishConfig": {
    "access": "public",
    "directory": "dist"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/interchain-kit/shell-extension"
  },
  "bugs": {
    "url": "https://github.com/interchain-kit/shell-extension/issues"
  },
  "scripts": {
    "clean": "makage clean",
    "build": "makage build",
    "build:dev": "npm run clean; tsc --declarationMap; tsc -p tsconfig.esm.json; npm run copy",
    "lint": "eslint . --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "watch:dev": "tsc -w -p tsconfig.esm.json & tsc -w",
    "prepack": "npm run build"
  },
  "keywords": [],
  "dependencies": {
    "@interchain-kit/core": "workspace:*"
  },
  "devDependencies": {
    "makage": "^0.1.12"
  }
}
