{
  "name": "@hyperweb/interchain-kit",
  "version": "0.0.1",
  "author": "Constructive <developers@constructive.io>",
  "private": true,
  "repository": {
    "type": "git",
    "url": "https://github.com/hyperweb-io/interchain-kit"
  },
  "license": "MIT",
  "scripts": {
    "clean": "pnpm -r run clean",
    "build": "pnpm -r --stream --filter '!@interchain-kit/vue-examples' --filter '!@interchain-kit/react-examples' --filter '!@interchain-kit/vanilla-examples' --filter '!e2e' --filter '!next-app-router' run build",
    "lint": "pnpm -r --parallel run lint",
    "test": "pnpm -r --stream --filter '!@interchain-kit/e2e' run test",
    "test:e2e": "cd e2e && npx playwright test",
    "test:e2e:ui": "cd e2e && npx playwright test --ui",
    "test:e2e:headed": "cd e2e && npx playwright test --headed",
    "test:e2e:debug": "cd e2e && npx playwright test --debug"
  },
  "devDependencies": {
    "@playwright/test": "^1.40.0",
    "@types/jest": "^29.5.11",
    "@types/node": "^20.12.7",
    "@typescript-eslint/eslint-plugin": "^7.10.0",
    "@typescript-eslint/parser": "^7.10.0",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "5.0.0",
    "eslint-plugin-simple-import-sort": "^12.1.0",
    "eslint-plugin-unused-imports": "^4.0.0",
    "jest": "^29.6.2",
    "lerna": "^6",
    "prettier": "2.8.8",
    "strip-ansi": "^6",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.1.6"
  }
}
