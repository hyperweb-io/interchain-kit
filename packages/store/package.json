{
  "name": "@interchain-kit/store",
  "version": "0.8.0",
  "author": "Hyperweb  <developers@hyperweb.io>",
  "description": "interchain-kit wallet connector store package",
  "main": "index.js",
  "module": "esm/index.js",
  "types": "index.d.ts",
  "homepage": "https://github.com/interchain-kit/store",
  "license": "MIT",
  "publishConfig": {
    "access": "public",
    "directory": "dist"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/interchain-kit/store"
  },
  "bugs": {
    "url": "https://github.com/interchain-kit/interchain-kit/issues"
  },
  "scripts": {
    "clean": "makage clean",
    "build": "makage build",
    "build:dev": "npm run clean; tsc --declarationMap; tsc -p tsconfig.esm.json; npm run copy",
    "lint": "eslint . --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "watch:dev": "tsc -w -p tsconfig.esm.json & tsc -w",
    "prepack": "npm run build"
  },
  "keywords": [],
  "devDependencies": {
    "makage": "^0.1.12"
  },
  "dependencies": {
    "@chain-registry/types": "^2.0.1",
    "@interchain-kit/core": "workspace:*",
    "@interchainjs/cosmos": "1.21.0",
    "@interchainjs/types": "1.21.0",
    "interchainjs": "1.21.0"
  }
}
